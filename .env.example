# Copy to .env and fill in real values. Never commit the real .env file.

ENVIRONMENT=local
DEBUG=true

JWT_SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=fingpt
POSTGRES_PASSWORD=fingpt
POSTGRES_DB=fingpt_enterprise

REDIS_URL=redis://localhost:6379/0

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=fingpt_documents

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=
EMBEDDING_MODEL=text-embedding-3-large
LLM_MODEL=gpt-4o-mini
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

AWS_REGION=ap-south-1
S3_BUCKET_DOCUMENTS=fingpt-enterprise-documents
