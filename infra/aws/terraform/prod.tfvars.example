# Copy to prod.tfvars and fill in real values, or pass equivalents as -var / TF_VAR_*.
# Never commit a filled-in tfvars file with real secrets.

aws_region     = "ap-south-1"
project_name   = "fingpt-enterprise"
environment    = "production"

container_image = "123456789012.dkr.ecr.ap-south-1.amazonaws.com/fingpt-enterprise-api:latest"

desired_count  = 2
fargate_cpu    = 1024
fargate_memory = 2048

db_instance_class = "db.t4g.micro"

acm_certificate_arn = "arn:aws:acm:ap-south-1:123456789012:certificate/REPLACE_ME"

# Secrets — prefer environment variables in CI (TF_VAR_db_password, TF_VAR_jwt_secret_key,
# TF_VAR_openai_api_key) over putting them in this file.
# db_password    = "..."
# jwt_secret_key = "..."
# openai_api_key = "..."
